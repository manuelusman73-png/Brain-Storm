{
  "dashboard": {
    "title": "Brain Storm - NestJS Metrics",
    "uid": "brainstorm-nestjs",
    "tags": ["nestjs", "brain-storm"],
    "timezone": "browser",
    "refresh": "30s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "HTTP Request Rate (req/s)",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total[5m])) by (method, route, status_code)",
            "legendFormat": "{{method}} {{route}} {{status_code}}"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "reqps" }
        }
      },
      {
        "id": 2,
        "title": "HTTP Error Rate (5xx)",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m]))",
            "legendFormat": "5xx errors/s"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "reqps", "color": { "fixedColor": "red", "mode": "fixed" } }
        }
      },
      {
        "id": 3,
        "title": "Credentials Issued (total)",
        "type": "stat",
        "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "sum(credential_issued_total)",
            "legendFormat": "Total"
          }
        ]
      },
      {
        "id": 4,
        "title": "BST Tokens Minted (total)",
        "type": "stat",
        "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "sum(bst_minted_total)",
            "legendFormat": "Total"
          }
        ]
      },
      {
        "id": 5,
        "title": "Credential Issuance Rate",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "sum(rate(credential_issued_total[5m])) by (credential_type)",
            "legendFormat": "{{credential_type}}"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "ops" }
        }
      },
      {
        "id": 6,
        "title": "Stellar RPC Latency p50 / p95 / p99",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(stellar_rpc_latency_seconds_bucket[5m])) by (le, method))",
            "legendFormat": "p50 {{method}}"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(stellar_rpc_latency_seconds_bucket[5m])) by (le, method))",
            "legendFormat": "p95 {{method}}"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(stellar_rpc_latency_seconds_bucket[5m])) by (le, method))",
            "legendFormat": "p99 {{method}}"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "id": 7,
        "title": "Node.js Memory Usage",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "process_resident_memory_bytes",
            "legendFormat": "RSS"
          },
          {
            "expr": "nodejs_heap_size_used_bytes",
            "legendFormat": "Heap Used"
          },
          {
            "expr": "nodejs_heap_size_total_bytes",
            "legendFormat": "Heap Total"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "bytes" }
        }
      },
      {
        "id": 8,
        "title": "Event Loop Lag",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 20, "w": 12, "h": 6 },
        "targets": [
          {
            "expr": "nodejs_eventloop_lag_seconds",
            "legendFormat": "Event Loop Lag"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "id": 9,
        "title": "CPU Usage",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 20, "w": 12, "h": 6 },
        "targets": [
          {
            "expr": "rate(process_cpu_user_seconds_total[1m])",
            "legendFormat": "User CPU"
          },
          {
            "expr": "rate(process_cpu_system_seconds_total[1m])",
            "legendFormat": "System CPU"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "percentunit" }
        }
      }
    ],
    "schemaVersion": 38,
    "version": 2
  },
  "overwrite": true
}
